{
  "name": "@stock-insight/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "preview": "vite preview --port 6100",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "test": "node --test test/*.test.ts",
    "smoke:api": "node scripts/smoke-dashboard-api.mjs",
    "start": "node .output/server/index.mjs",
    "lint": "oxlint src config vite.config.ts",
    "lint:fix": "oxlint --fix src config vite.config.ts",
    "format": "oxfmt src config package.json tsconfig.json tsconfig.base.json tsconfig.app.json tsconfig.node.json vite.config.ts",
    "format:check": "oxfmt --check src config package.json tsconfig.json tsconfig.base.json tsconfig.app.json tsconfig.node.json vite.config.ts"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "@stock-insight/api": "workspace:*",
    "@stock-insight/api-client": "workspace:*",
    "@stock-insight/contracts": "workspace:*",
    "@stock-insight/ui": "workspace:*",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-start": "1.168.25",
    "echarts": "^6.1.0",
    "gsap": "3.15.0",
    "lucide-react": "1.17.0",
    "nitro": "3.0.260603-beta",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "0.2.3",
    "@tanstack/router-plugin": "1.168.18",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "wait-on": "9.0.10"
  }
}
