{
  "name": "@stock-insight/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/*.test.ts",
    "test:core-release": "node scripts/run-core-release-gate.mjs",
    "backfill:phase35": "node src/backfill/run-phase35.ts",
    "backfill:phase35:apply": "node src/backfill/run-phase35.ts --apply",
    "backfill:phase10": "node src/backfill/run-phase10.ts",
    "backfill:phase10:apply": "node src/backfill/run-phase10.ts --apply",
    "backfill:phase11": "node src/backfill/run-phase11.ts",
    "backfill:phase11:apply": "node src/backfill/run-phase11.ts --apply",
    "backfill:phase12": "node src/backfill/run-phase12.ts",
    "backfill:phase12:apply": "node src/backfill/run-phase12.ts --apply",
    "backfill:phase4": "node src/backfill/run-phase4.ts",
    "backfill:phase4:apply": "node src/backfill/run-phase4.ts --apply",
    "backfill:sec-edgar:dry-run": "node src/backfill/run-sec-edgar.ts",
    "backfill:sec-edgar:apply": "node src/backfill/run-sec-edgar.ts --apply",
    "backfill:opendart:dry-run": "node src/backfill/run-opendart.ts",
    "backfill:opendart:apply": "node src/backfill/run-opendart.ts --apply",
    "ingest:news:dry-run": "node src/ingest/run-news-rss.ts",
    "ingest:news:apply": "node src/ingest/run-news-rss.ts --apply",
    "ingest:news:translate:dry-run": "node src/ingest/run-news-translation.ts",
    "ingest:news:translate:apply": "node src/ingest/run-news-translation.ts --apply",
    "ingest:ohlcv:dry-run": "node src/ingest/run-ohlcv.ts",
    "ingest:ohlcv:apply": "node src/ingest/run-ohlcv.ts --apply",
    "analytics:v2-graph:dry-run": "node src/analytics/run-v2-graph-publish.ts",
    "analytics:v2-graph:apply": "node src/analytics/run-v2-graph-publish.ts --apply",
    "analytics:v2-l5:dry-run": "node src/analytics/run-v2-analytics-publish.ts",
    "analytics:v2-l5:apply": "node src/analytics/run-v2-analytics-publish.ts --apply",
    "ops:outbox:dry-run": "node src/ops/run-outbox-delivery.ts",
    "ops:outbox:apply": "node src/ops/run-outbox-delivery.ts --apply --loop",
    "lint": "oxlint src",
    "format": "oxfmt src package.json tsconfig.json",
    "format:check": "oxfmt --check src package.json tsconfig.json"
  },
  "dependencies": {
    "@stock-insight/contracts": "workspace:*",
    "@stock-insight/db-schema": "workspace:*",
    "@types/pg": "^8.20.0",
    "h3-js": "4.5.0",
    "pg": "^8.22.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "25.9.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "6.0.3"
  }
}
