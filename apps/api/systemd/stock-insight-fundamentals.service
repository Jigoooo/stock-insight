[Unit]
Description=Stock Insight OpenDART and SEC fundamentals refresh
StartLimitIntervalSec=1h
StartLimitBurst=4

[Service]
Type=oneshot
WorkingDirectory=/home/jigoo/.hermes/workspace/stock-insight
ExecStart=/home/jigoo/.hermes/workspace/stock-insight/apps/api/scripts/run_company_fundamentals.sh
TimeoutStartSec=30min
Restart=on-failure
RestartSec=15min
UMask=0077
NoNewPrivileges=true

[Install]
WantedBy=default.target
