{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "ignorePatterns": [
    "apps/web/src/routeTree.gen.ts",
    "node_modules/**",
    "**/node_modules/**",
    "**/.output/**",
