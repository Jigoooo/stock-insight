{
  "name": "stock-insight-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @stock-insight/web dev",
    "preview": "pnpm --filter @stock-insight/web preview",
    "start": "pnpm --filter @stock-insight/web start",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint apps packages e2e playwright.config.ts",
    "lint:fix": "oxlint --fix apps packages e2e playwright.config.ts",
    "format": "oxfmt apps packages e2e package.json pnpm-workspace.yaml turbo.json tsconfig.json tsconfig.base.json playwright.config.ts",
    "format:check": "oxfmt --check apps packages e2e package.json pnpm-workspace.yaml turbo.json tsconfig.json tsconfig.base.json playwright.config.ts",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@types/node": "25.9.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.6.3",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "overrides": {
      "eslint-plugin-react-hooks>zod-validation-error": "^4.0.2"
    }
  }
}
