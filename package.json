{
  "name": "stock-insight",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "preview": "vite preview --port 6100",
    "build": "tsc -b && vite build",
    "start": "node .output/server/index.mjs",
    "lint": "oxlint src e2e config vite.config.ts playwright.config.ts",
    "lint:fix": "oxlint --fix src e2e config vite.config.ts playwright.config.ts",
    "format": "oxfmt src e2e config package.json tsconfig.json tsconfig.base.json tsconfig.app.json tsconfig.node.json vite.config.ts playwright.config.ts",
    "format:check": "oxfmt --check src e2e config package.json tsconfig.json tsconfig.base.json tsconfig.app.json tsconfig.node.json vite.config.ts playwright.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@gsap/react": "2.1.2",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-start": "1.168.25",
    "echarts": "^6.1.0",
    "gsap": "3.15.0",
    "lucide-react": "1.17.0",
    "nitro": "3.0.260603-beta",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@tanstack/router-plugin": "1.168.18",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "wait-on": "9.0.10"
  },
  "pnpm": {
    "overrides": {
      "eslint-plugin-react-hooks>zod-validation-error": "^4.0.2"
    }
  }
}
