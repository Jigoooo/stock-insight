{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "../../..",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@stock-insight/contracts/*": ["packages/contracts/src/*"],
      "react": ["apps/web/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["apps/web/node_modules/@types/react/jsx-runtime.d.ts"],
      "react-dom/client": ["apps/web/node_modules/@types/react-dom/client.d.ts"]
    }
  },
  "include": ["main.tsx", "../../../apps/web/src/vite-env.d.ts"]
}
